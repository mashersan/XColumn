<Window x:Class="XColumn.Views.ExtensionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:p="clr-namespace:XColumn.Properties"
        Title="{x:Static p:Resources.ExtensionManagement}" 
        Height="450" 
        Width="600"
        MinWidth="550" 
        MinHeight="350" 
        WindowStartupLocation="CenterOwner"
        ui:WindowHelper.UseModernWindowStyle="True"
        Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="{x:Static p:Resources.Extension_AddFromFolder}" Command="{Binding AddExtensionCommand}" Margin="0,0,10,0"/>
            <Button Content="{x:Static p:Resources.Extension_ImportFromChrome}" Command="{Binding ImportFromChromeCommand}" Margin="0,0,10,0"/>
        </StackPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding Extensions}" HorizontalContentAlignment="Stretch" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" Background="Transparent">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"
                                       Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Path}" FontSize="11" 
                                       Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" 
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="{x:Static p:Resources.Extension_Options}" Margin="5,0" Padding="8,2" 
                                    Command="{Binding DataContext.OpenOptionsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <CheckBox IsChecked="{Binding IsEnabled}" Content="{x:Static p:Resources.Extension_Enabled}" VerticalAlignment="Center" Margin="10,0"/>
                            <Button Content="{x:Static p:Resources.Extension_OpenFolder}" Margin="5,0,0,0"
                                    Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="{x:Static p:Resources.Extension_Remove}" Margin="10,0,0,0" Padding="8,2" 
                                    Command="{Binding DataContext.RemoveExtensionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Background="#33FF0000" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" BorderBrush="Red"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,5">
            <Button Content="{x:Static p:Resources.Extension_OK}" Width="80" IsDefault="True" Command="{Binding OkCommand}" Margin="0,0,10,0"/>
            <Button Content="{x:Static p:Resources.Extension_Cancel}" Width="80" IsCancel="True" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>