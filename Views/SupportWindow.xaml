<Window x:Class="XColumn.Views.SupportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:p="clr-namespace:XColumn.Properties"
        Title="{x:Static p:Resources.Support_Title}"
        SizeToContent="Height" 
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource DefaultWindowStyle}"
        Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25">
            <TextBlock Text="{x:Static p:Resources.Support_Header}" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="{x:Static p:Resources.Support_Body}" TextWrapping="Wrap" FontSize="14" Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" HorizontalAlignment="Center" TextAlignment="Center" LineHeight="22" />
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
            <Button Width="280" Height="50" Margin="0,0,0,15" Click="BuyMeACoffee_Click" Background="#FFDD00" BorderThickness="0" ui:ControlHelper.CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="☕" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="Black"/>
                    <TextBlock Text="Buy Me a Coffee" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="Black"/>
                </StackPanel>
            </Button>

            <Button Width="280" Height="50" Click="GithubSponsors_Click" Background="#EA4AAA" BorderThickness="0" ui:ControlHelper.CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💖" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="White"/>
                    <TextBlock Text="GitHub Sponsors" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="White"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Button Grid.Row="2" Content="閉じる" Width="120" Height="35" HorizontalAlignment="Center" Margin="0,30,0,0" IsCancel="True" Click="Close_Click"/>
    </Grid>
</Window>