<Window x:Class="XColumn.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:p="clr-namespace:XColumn.Properties"
        mc:Ignorable="d"
        Title="{x:Static p:Resources.Settings_Title}" 
        Height="750" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource DefaultWindowStyle}"
        Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" 
                    Margin="0,0,0,12">
            <TabItem Header="{x:Static p:Resources.Settings_Tab_Display}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              Padding="0,0,12,0">
                    <StackPanel Margin="10">
                        <TextBlock Text="{x:Static p:Resources.Settings_Language}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <ComboBox Name="LanguageComboBox" 
                                  Margin="10,0,0,5" 
                                  HorizontalAlignment="Left" 
                                  Width="200"
                                  SelectedValuePath="Tag" 
                                  SelectedValue="{Binding SelectedLanguage}">
                            <ComboBoxItem Content="日本語 (Japanese)" 
                                          Tag="ja-JP"/>
                            <ComboBoxItem Content="English" 
                                          Tag="en-US"/>
                        </ComboBox>
                        <TextBlock Text="{x:Static p:Resources.Msg_RestartRequired}" 
                                   FontSize="11" 
                                   Foreground="Gray" 
                                   Margin="10,0,0,20"/>

                        <TextBlock Text="{x:Static p:Resources.Settings_Theme}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <ComboBox Name="ThemeComboBox" 
                                  Margin="10,0,0,20" 
                                  HorizontalAlignment="Left" 
                                  Width="200"
                                  SelectedValuePath="Tag" 
                                  SelectedValue="{Binding SelectedTheme}">
                            <ComboBoxItem Content="System" 
                                          Tag="System"/>
                            <ComboBoxItem Content="Light" 
                                          Tag="Light"/>
                            <ComboBoxItem Content="Dark" 
                                          Tag="Dark"/>
                        </ComboBox>

                        <TextBlock Margin="10,0,0,20" 
                                   FontSize="12">
                            <Hyperlink NavigateUri="https://x.com/settings/display" 
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                <Run Text="{x:Static p:Resources.Settings_Link_DisplayWeb}"/>
                            </Hyperlink>
                        </TextBlock>

                        <TextBlock Text="{x:Static p:Resources.Settings_Font}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <Grid Margin="10,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="Font:" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="1" 
                                      Name="FontFamilyComboBox" 
                                      IsEditable="True" 
                                      Margin="0,0,15,0"
                                      ItemsSource="{Binding FontList}" 
                                      Text="{Binding FontFamily}"
                                      ToolTip="{x:Static p:Resources.Tooltip_FontFamily}"/>
                            <TextBlock Grid.Column="2" Text="Size(px):" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,5,0"/>
                            <TextBox Grid.Column="3" 
                                     Name="FontSizeTextBox" 
                                     Width="50" 
                                     HorizontalAlignment="Left" 
                                     VerticalAlignment="Center" 
                                     VerticalContentAlignment="Center"
                                     Text="{Binding FontSizeText}" 
                                     ToolTip="{x:Static p:Resources.Tooltip_FontSize}"/>
                        </Grid>

                        <TextBlock Text="{x:Static p:Resources.Settings_DisplayOptions}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <StackPanel Margin="10,0,0,0">
                            <CheckBox Name="HideMenuHomeCheckBox" 
                                      Content="{x:Static p:Resources.Settings_HideMenuHome}" 
                                      Margin="0,0,0,8" 
                                      IsChecked="{Binding HideMenuInHome}"/>
                            <CheckBox Name="HideMenuNonHomeCheckBox" 
                                      Content="{x:Static p:Resources.Settings_HideMenuNonHome}" 
                                      Margin="0,0,0,8" 
                                      IsChecked="{Binding HideMenuInNonHome}"/>
                            <CheckBox Name="HideListHeaderCheckBox" 
                                      Content="{x:Static p:Resources.Settings_HideListHeader}" 
                                      Margin="0,0,0,8" 
                                      IsChecked="{Binding HideListHeader}"/>
                            <CheckBox Name="HideRightSidebarCheckBox" 
                                      Content="{x:Static p:Resources.Settings_HideRightSidebar}" 
                                      Margin="0,0,0,8" 
                                      IsChecked="{Binding HideRightSidebar}"/>
                            <CheckBox Name="ShowAbsoluteTimeCheckBox" 
                                      Content="{x:Static p:Resources.Settings_ShowAbsoluteTime}" 
                                      Margin="0,0,0,8" 
                                      IsChecked="{Binding ShowAbsoluteTime}"/>
                            <CheckBox Name="ShowRateLimitRemainingCheckBox"
                                      Content="{x:Static p:Resources.Settings_ShowRateLimitRemaining}"
                                      Margin="0,0,0,8"
                                      IsChecked="{Binding ShowRateLimitRemaining}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{x:Static p:Resources.Settings_Tab_Column}">
                <StackPanel Margin="10">
                    <TextBlock Text="{x:Static p:Resources.Settings_Layout}" 
                               FontWeight="Bold" 
                               Margin="0,0,0,8" 
                               Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                    <CheckBox Name="UseUniformGridCheckBox" 
                              Content="{x:Static p:Resources.Settings_UniformGrid}" 
                              Margin="10,0,0,8"
                              IsChecked="{Binding UseUniformGrid}" 
                              ToolTip="{x:Static p:Resources.Tooltip_UniformGrid}"/>
                    <CheckBox Name="ShowColumnUrlCheckBox" 
                              Content="{x:Static p:Resources.Settings_ShowColumnUrl}" 
                              Margin="10,0,0,8"
                              IsChecked="{Binding ShowColumnUrl}"/>

                    <TextBlock Text="{x:Static p:Resources.Settings_ColumnWidth}" 
                               Margin="10,10,0,5"/>
                    <Grid Margin="10,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Name="ColumnWidthSlider" 
                                Grid.Column="0" 
                                Minimum="300" 
                                Maximum="1024" 
                                TickFrequency="10" 
                                IsSnapToTickEnabled="True" 
                                VerticalAlignment="Center"
                                Value="{Binding ColumnWidth}" 
                                IsEnabled="{Binding IsColumnWidthSliderEnabled}"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding ElementName=ColumnWidthSlider, Path=Value}" 
                                   VerticalAlignment="Center" 
                                   Margin="10,0,0,0" Width="30" 
                                   TextAlignment="Right"/>
                    </Grid>

                    <Separator Margin="0,0,0,15"/>

                    <TextBlock Text="{x:Static p:Resources.Settings_NewColumnPos}" 
                               FontWeight="Bold" 
                               Margin="0,0,0,8" 
                               Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                    <CheckBox Name="AddColumnToLeftCheckBox" 
                              Content="{x:Static p:Resources.Settings_AddLeft}" 
                              Margin="10,0,0,5"
                              IsChecked="{Binding AddColumnToLeft}" 
                              ToolTip="{x:Static p:Resources.Tooltip_AddColumnLeft}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="{x:Static p:Resources.Settings_Tab_Behavior}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="{x:Static p:Resources.Settings_BasicBehavior}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <CheckBox Name="UseSoftRefreshCheckBox" 
                                  Content="{x:Static p:Resources.Settings_SoftRefresh}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding UseSoftRefresh}" 
                                  ToolTip="{x:Static p:Resources.Tooltip_SoftRefresh}"/>
                        <CheckBox Name="KeepUnreadPositionCheckBox" 
                                  Content="{x:Static p:Resources.Settings_KeepUnread}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding KeepUnreadPosition}" 
                                  ToolTip="{x:Static p:Resources.Tooltip_KeepUnread}"/>
                        <CheckBox Name="UseRefreshJitterCheckBox" 
                                  Content="{x:Static p:Resources.Settings_RefreshJitter}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding UseRefreshJitter}" 
                                  ToolTip="{x:Static p:Resources.Tooltip_RefreshJitter}"/>
                        <CheckBox Name="IgnoreRateLimit429CheckBox" 
                                  Content="{x:Static p:Resources.Settings_IgnoreRateLimit}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding IgnoreRateLimit429}" 
                                  ToolTip="{x:Static p:Resources.Tooltip_IgnoreRateLimit}"/>
                        <StackPanel Orientation="Horizontal" 
                                    Margin="28,0,0,8">
                            <TextBlock Text="TLトップ判定の許容誤差(px):" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,10,0"/>
                            <TextBox Name="ScrollTopToleranceTextBox" 
                                     Width="60" 
                                     VerticalContentAlignment="Center" 
                                     MaxLength="4" 
                                     PreviewTextInput="NumberValidationTextBox"
                                     Text="{Binding ScrollTopToleranceText}"/>
                        </StackPanel>
                        <CheckBox Name="EnableWindowSnapCheckBox" 
                                  Content="{x:Static p:Resources.Settings_WindowSnap}" 
                                  Margin="10,0,0,5"
                                  IsChecked="{Binding EnableWindowSnap}"/>
                        <TextBlock Text="*Press Ctrl to disable temporarily" 
                                   Margin="28,0,0,20" 
                                   Foreground="Gray" 
                                   FontSize="11"/>

                        <TextBlock Text="{x:Static p:Resources.Settings_AutoShutdownTitle}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <CheckBox Name="AutoShutdownCheckBox" 
                                  Content="{x:Static p:Resources.Settings_AutoShutdownEnable}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding AutoShutdownEnabled}"/>
                        <StackPanel Orientation="Horizontal" 
                                    Margin="28,0,0,20">
                            <TextBlock Text="{x:Static p:Resources.Settings_AutoShutdownWait}" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,10,0"/>
                            <TextBox Name="AutoShutdownMinutesTextBox" 
                                     Width="60" 
                                     VerticalContentAlignment="Center" 
                                     MaxLength="4" 
                                     PreviewTextInput="NumberValidationTextBox"
                                     Text="{Binding AutoShutdownMinutesText}" 
                                     IsEnabled="{Binding AutoShutdownEnabled}"/>
                            <TextBlock Text="{x:Static p:Resources.Settings_AutoShutdownMinutes}" 
                                       VerticalAlignment="Center" 
                                       Margin="10,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="{x:Static p:Resources.Settings_FocusMode}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <CheckBox Name="DisableFocusModeOnMediaClickCheckBox" 
                                  Content="{x:Static p:Resources.Settings_DisableFocusMedia}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding DisableFocusModeOnMediaClick}"/>
                        <CheckBox Name="DisableFocusModeOnTweetClickCheckBox" 
                                  Content="{x:Static p:Resources.Settings_DisableFocusTweet}" 
                                  Margin="10,0,0,20"
                                  IsChecked="{Binding DisableFocusModeOnTweetClick}"/>

                        <TextBlock Text="{x:Static p:Resources.Settings_Section_MediaWeb}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <CheckBox Name="ForceDisableAutoPlayCheckBox" 
                                  Content="{x:Static p:Resources.Settings_ForceDisableAutoPlay}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding ForceDisableAutoPlay}" 
                                  ToolTip="{x:Static p:Resources.Tooltip_ForceDisableAutoPlay}"/>

                        <TextBlock Margin="10,0,0,20" 
                                   FontSize="12">
                            <Hyperlink NavigateUri="https://x.com/settings/autoplay" 
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                <Run Text="{x:Static p:Resources.Settings_Link_AutoplayWeb}"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{x:Static p:Resources.Settings_Tab_Experimental}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              Padding="0,0,12,0">
                    <StackPanel Margin="10">
                        <TextBlock Text="{x:Static p:Resources.Settings_ExperimentalNote}" 
                                   FontSize="11" 
                                   Foreground="Gray" 
                                   Margin="10,0,0,12"/>

                        <CheckBox Name="UseExperimentalFeaturesCheckBox" 
                                  Content="{x:Static p:Resources.Settings_OtherProfileTimeline}" 
                                  Margin="10,0,0,12"
                                  IsChecked="{Binding UseExperimentalFeatures}" 
                                  ToolTip="{x:Static p:Resources.Tooltip_OtherProfileTimeline}"/>

                        <CheckBox Name="AllowExternalSitesCheckBox" 
                                  Content="{x:Static p:Resources.Settings_AllowExternalSites}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding AllowExternalSites}" 
                                  ToolTip="{x:Static p:Resources.Tooltip_AllowExternalSites}"/>

                        <CheckBox Name="UseTwoTierLayoutCheckBox" 
                                  Content="{x:Static p:Resources.Settings_TwoTierLayout}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding UseTwoTierLayout}" 
                                  ToolTip="{x:Static p:Resources.Tooltip_TwoTierLayout}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{x:Static p:Resources.Settings_Tab_Others}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              Padding="0,0,12,0">
                    <StackPanel Margin="10">

                        <TextBlock Text="{x:Static p:Resources.Settings_StartupProfile}" 
                                   FontWeight="Bold" Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <ComboBox Name="StartupProfileComboBox" 
                                  Margin="10,0,0,20" 
                                  HorizontalAlignment="Left" 
                                  Width="250" 
                                  DisplayMemberPath="Display"
                                  ItemsSource="{Binding StartupProfiles}" 
                                  SelectedItem="{Binding SelectedStartupProfile}"/>

                        <TextBlock Text="{x:Static p:Resources.Settings_UpdateCheck}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <CheckBox Name="CheckUpdateCheckBox" 
                                  Content="{x:Static p:Resources.Settings_CheckUpdate}" 
                                  Margin="10,0,0,20"
                                  IsChecked="{Binding CheckForUpdates}"/>

                        <TextBlock Text="{x:Static p:Resources.Settings_ServerMonitor}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <Grid Margin="10,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" 
                                        Grid.Column="0">
                                <TextBlock Text="{x:Static p:Resources.Settings_CheckInterval}" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,10,0"/>
                                <ComboBox Name="ServerCheckIntervalComboBox" 
                                          Width="120" 
                                          VerticalContentAlignment="Center"
                                          SelectedValuePath="Tag" 
                                          SelectedValue="{Binding SelectedServerInterval}">
                                    <ComboBoxItem Content="1 min" Tag="1"/>
                                    <ComboBoxItem Content="3 min" Tag="3"/>
                                    <ComboBoxItem Content="5 min" Tag="5"/>
                                    <ComboBoxItem Content="10 min" Tag="10"/>
                                    <ComboBoxItem Content="15 min" Tag="15"/>
                                    <ComboBoxItem Content="30 min" Tag="30"/>
                                    <ComboBoxItem Content="60 min" Tag="60"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{x:Static p:Resources.Settings_ListAutoNav}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <TextBlock Text="{x:Static p:Resources.Settings_ListAutoNavDelay}" 
                                   Margin="10,0,0,5"/>
                        <TextBox Name="ListAutoNavDelayTextBox" 
                                 Width="100" 
                                 HorizontalAlignment="Left" 
                                 Margin="10,0,0,5"
                                 Text="{Binding ListAutoNavDelayText}" 
                                 ToolTip="{x:Static p:Resources.Tooltip_ListAutoNavDelay}"/>
                        <TextBlock Text="{x:Static p:Resources.Settings_ListAutoNavDelayWarning}" 
                                   FontSize="11" 
                                   Foreground="Gray" 
                                   Margin="12,0,0,20"/>

                        <!-- PiP・外部リンク -->
                        <TextBlock Text="{x:Static p:Resources.Settings_Section_PipLink}" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,8" 
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>

                        <CheckBox Name="AutoPipForVideoCheckBox" 
                                  Content="{x:Static p:Resources.Settings_AutoPipForVideo}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding AutoPipForVideo}" 
                                  ToolTip="{x:Static p:Resources.Tooltip_AutoPipForVideo}"/>

                        <CheckBox Name="PipAlwaysOnTopCheckBox" 
                                  Content="{x:Static p:Resources.Settings_PipAlwaysOnTop}" 
                                  Margin="10,0,0,8"
                                  IsChecked="{Binding PipAlwaysOnTop}"/>

                        <TextBlock Text="{x:Static p:Resources.Settings_ExternalLinkOpen}"
                                   FontWeight="Bold"
                                   Margin="0,16,0,8"
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                        <ComboBox Name="ExternalLinkModeComboBox"
                                  Margin="10,0,0,8"
                                  HorizontalAlignment="Left"
                                  Width="220"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding SelectedExternalLinkMode}">
                            <ComboBoxItem Content="{x:Static p:Resources.Settings_ExternalLink_Default}" Tag="Default"/>
                            <ComboBoxItem Content="{x:Static p:Resources.Settings_ExternalLink_Pip}"     Tag="Pip"/>
                            <ComboBoxItem Content="{x:Static p:Resources.Settings_ExternalLink_Focus}"   Tag="Focus"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{x:Static p:Resources.Settings_Tab_Mute}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{x:Static p:Resources.Settings_NgWordTitle}" 
                               FontWeight="Bold" 
                               Margin="0,0,0,8" 
                               Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                    <TextBlock Text="{x:Static p:Resources.Settings_NgWordDesc}" 
                               HorizontalAlignment="Right" 
                               FontSize="12" 
                               Margin="0,0,0,10" 
                               Foreground="Gray"/>

                    <Grid Grid.Row="1" 
                          Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="NgWordInputBox" 
                                 ui:ControlHelper.PlaceholderText="{x:Static p:Resources.Settings_NgWordPlaceholder}" 
                                 Margin="0,0,10,0"
                                 Text="{Binding NgWordInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="{x:Static p:Resources.Common_Add}" 
                                Grid.Column="1" 
                                Command="{Binding AddNgWordCommand}"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListBox Name="NgWordListBox" 
                                 Margin="0,0,0,10" 
                                 SelectionMode="Extended" 
                                 ItemsSource="{Binding NgWords}"/>
                        <Button Grid.Row="1" Content="{x:Static p:Resources.Common_DeleteSelected}" 
                                HorizontalAlignment="Right"
                                Command="{Binding DeleteNgWordCommand}"
                                CommandParameter="{Binding SelectedItems, ElementName=NgWordListBox}"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="{x:Static p:Resources.Settings_Tab_CSS}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" 
                               Text="{x:Static p:Resources.Settings_CssLabel}" 
                               Margin="0,0,0,8" 
                               Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                    <TextBox Grid.Row="1" 
                             Name="CustomCssTextBox" 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" 
                             FontFamily="Consolas, Courier New, Monospace" 
                             Padding="5"
                             Text="{Binding CustomCss}"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="{x:Static p:Resources.Common_OK}" 
                    Width="100" 
                    Margin="0,0,10,0" 
                    IsDefault="True" 
                    Command="{Binding OkCommand}"/>
            <Button Content="{x:Static p:Resources.Common_Cancel}" 
                    Width="110" 
                    IsCancel="True" 
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>